{
  "name": "wechat-opencode",
  "version": "1.0.0",
  "description": "Chat with OpenCode from WeChat - a WeChat bridge for local OpenCode",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/main.js",
    "run": "node dist/main.js start",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "setup": "node dist/main.js setup",
    "daemon": "bash scripts/daemon.sh"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "wechat",
    "opencode",
    "openai",
    "bridge",
    "chat",
    "skill"
  ],
  "author": "Wechat-ggGitHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wechat-ggGitHub/wechat-opencode.git"
  }
}
